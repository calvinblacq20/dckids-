# Runtime
NODE_ENV=development
PORT=3001

# Persistent storage. Render production uses DATA_DIR=/var/data.
# DB_PATH, UPLOAD_DIR, and BACKUP_DIR are optional absolute overrides.
DATA_DIR=
DB_PATH=
UPLOAD_DIR=
BACKUP_DIR=

# Production security and public URL
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
ALLOWED_ORIGINS=https://your-domain.example
APP_URL=https://your-domain.example
OWNER_EMAIL=owner@example.com

# Passwordless admin email through Resend
RESEND_API_KEY=replace-with-your-resend-api-key
RESEND_FROM=DC Kids <no-reply@your-domain.example>

# Optional Google admin sign-in
GOOGLE_CLIENT_ID=

# Customer accounts remain disabled until their UI is restored
CUSTOMER_ACCOUNTS_ENABLED=false

# Optional Telegram order alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: disable the in-process daily backup scheduler
BACKUP_SCHEDULE_DISABLED=false
