# Runtime
NODE_ENV=development
PORT=3001

# Persistent storage. Railway production: DATA_DIR=/data
# DB_PATH, UPLOAD_DIR, and BACKUP_DIR are optional explicit overrides.
DATA_DIR=
DB_PATH=
UPLOAD_DIR=
BACKUP_DIR=

# Production security and public URL
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
ALLOWED_ORIGINS=https://dckidsgh.com,https://www.dckidsgh.com
APP_URL=https://dckidsgh.com
OWNER_EMAIL=info@dckidsbrand.com

# Passwordless admin email through Resend
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM=DC Kids <no-reply@updates.dckidsgh.com>

# Optional Google admin sign-in
GOOGLE_CLIENT_ID=

# Customer accounts remain disabled until their UI is restored
CUSTOMER_ACCOUNTS_ENABLED=false

# Optional Telegram order alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
